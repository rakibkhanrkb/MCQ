rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Helpers
    function isSignedIn() { return request.auth != null; }

    // Test Connection Path (to support connection testing gracefully)
    match /test/connection {
      allow read: if true;
    }

    // Collection: Exams
    match /exams/{examId} {
      allow read: if true;
      allow write: if true;

      // Subcollection: MCQ Pool under Exams
      match /mcq_pool/{questionId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // Collection: Exam Results
    match /exam_results/{resultId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // Collection: Users
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // Collection: Payments
    match /payments/{paymentId} {
      allow read: if true;
      allow write: if true;
    }

    // Collection: Questions
    match /questions/{questionId} {
      allow read: if true;
      allow write: if true;
    }

    // Collection: Exam Routines
    match /exam_routines/{routineId} {
      allow read: if true;
      allow write: if true;
    }

    // Collection: Global settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    // Collection: Admins
    match /admins/{adminId} {
      allow read: if true;
      allow write: if true;
    }

    // Collection: Activity Logs
    match /activity_logs/{logId} {
      allow read, write: if true;
    }
  }
}
